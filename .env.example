# Ernos 3.0 Configuration
# Copy this file to .env and fill in your values

# Discord
DISCORD_TOKEN=your_discord_bot_token
ADMIN_ID=your_discord_user_id

# Channels
TARGET_CHANNEL_ID=your_main_channel_id
SUPPORT_CHANNEL_ID=your_support_channel_id
MIND_CHANNEL_ID=your_mind_channel_id
RESEARCH_CHANNEL_ID=your_research_channel_id
PERSONA_CHAT_CHANNEL_ID=your_persona_channel_id

# Ollama (LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CLOUD_MODEL=gemini-3-flash-preview:latest
OLLAMA_LOCAL_MODEL=qwen3-vl:235b
OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# Steering Engine (Local)
STEERING_MODEL_PATH=./models/my_model.gguf
CONTROL_VECTOR_PATH=./models/my_vec.gguf

# Image/Video Generation
FLUX_MODEL_PATH=black-forest-labs/FLUX.1-dev
LTX_MODEL_PATH=Lightricks/LTX-Video
HF_API_TOKEN=your_huggingface_api_token

# Knowledge Graph (Neo4j)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# Privacy
ENABLE_PRIVACY_SCOPES=true

# Python Path (set automatically by start_ernos.sh)
# PYTHONPATH=/path/to/Ernos 3.0
