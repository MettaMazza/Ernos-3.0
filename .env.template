# ═══════════════════════════════════════════════
# Ernos 3.0 — Environment Configuration Template
# ═══════════════════════════════════════════════
#
# Copy this file to .env and fill in your values:
#   cp .env.template .env
#
# All fields with empty defaults MUST be configured.
# Fields with values are sensible defaults.

# ─── Discord Bot ───────────────────────────────
# Create a bot at https://discord.com/developers/applications
DISCORD_TOKEN=

# Your Discord user ID (right-click → Copy User ID)
ADMIN_ID=
# Comma-separated admin user IDs (grants admin commands)
ADMIN_IDS=

# ─── Channel IDs ───────────────────────────────
# Set these to your Discord server's channel IDs
# 0 = channel disabled/unconfigured
TARGET_CHANNEL_ID=0
SUPPORT_CHANNEL_ID=0
MIND_CHANNEL_ID=0
DEV_CHANNEL_ID=0
RESEARCH_CHANNEL_ID=0
PERSONA_CHAT_CHANNEL_ID=0
OUTREACH_CHANNEL_ID=0
CODE_AUDIT_CHANNEL_ID=0
SKILL_PROPOSALS_CHANNEL_ID=0
SCHEDULED_TASKS_CHANNEL_ID=0
ERNOS_CODE_CHANNEL_ID=0

# ─── Moderation ────────────────────────────────
# Comma-separated Discord user IDs to block
BLOCKED_IDS=
DM_BANNED_IDS=

# ─── LLM Inference (Ollama) ───────────────────
# Default: Docker internal network address
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CLOUD_MODEL=gemini-3-flash-preview:latest
OLLAMA_LOCAL_MODEL=qwen3-vl:235b
OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# ─── Steering Engine (llama.cpp) ───────────────
# Path to local GGUF model files (inside container)
STEERING_MODEL_PATH=/app/models/my_model.gguf
CONTROL_VECTOR_PATH=/app/models/my_vec.gguf

# ─── Neo4j Knowledge Graph ────────────────────
# Default: Docker internal network address
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ─── Creative / Media Generation ──────────────
# HuggingFace API token (for image/video generation)
HF_API_TOKEN=
FLUX_MODEL_PATH=black-forest-labs/FLUX.1-dev
LTX_MODEL_PATH=Lightricks/LTX-Video

# ─── Privacy ───────────────────────────────────
ENABLE_PRIVACY_SCOPES=true

# ─── Monetization (optional) ──────────────────
PATREON_URL=

# ─── Python Path (do not change) ──────────────
PYTHONPATH=/app
