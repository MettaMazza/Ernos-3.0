{
    "name": "ernos-mineflayer",
    "version": "1.0.0",
    "description": "Mineflayer bot for Ernos gaming",
    "main": "bot.js",
    "scripts": {
        "test": "jest --coverage --forceExit",
        "test:watch": "jest --watch"
    },
    "jest": {
        "testMatch": [
            "**/__tests__/**/*.test.js"
        ],
        "collectCoverageFrom": [
            "*.js",
            "commands/*.js",
            "!node_modules/**",
            "!package-lock.json"
        ]
    },
    "dependencies": {
        "canvas": "^3.2.1",
        "mineflayer": "^4.14.0",
        "mineflayer-armor-manager": "^2.0.1",
        "mineflayer-auto-eat": "^5.0.3",
        "mineflayer-blockfinder": "^0.0.7",
        "mineflayer-collectblock": "^1.6.0",
        "mineflayer-pathfinder": "^2.4.5",
        "mineflayer-pvp": "^1.3.2",
        "mineflayer-tool": "^1.2.0",
        "prismarine-item": "^1.17.0",
        "prismarine-viewer": "^1.33.0",
        "puppeteer": "^24.37.1",
        "vec3": "^0.1.10"
    },
    "devDependencies": {
        "jest": "^30.2.0"
    }
}
